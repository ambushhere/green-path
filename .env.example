# ─── Frontend environment variables ─────────────────────────────────────────
# Copy this file to .env and fill in values as needed.

# Base URL path for the app (used by Vite for asset prefixing).
# Defaults to /green-path/ for GitHub Pages. Set to / for local or other hosts.
VITE_BASE_URL=

# Optional proxy base URL. When set, all API calls are routed through the proxy
# instead of hitting third-party APIs directly from the browser.
# Example: http://localhost:8787
VITE_API_PROXY_BASE_URL=

# Optional direct API base URL overrides (only used when proxy is NOT configured).
VITE_ROUTING_API_BASE_URL=
VITE_GEOCODING_API_BASE_URL=
VITE_AIR_QUALITY_API_BASE_URL=
VITE_WAQI_API_BASE_URL=

# Preferred language for geocoding results (Nominatim accept-language header).
# Defaults to "en".
VITE_GEOCODING_LANGUAGE=en
